generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(uuid())
  username    String      @unique
  email       String      @unique
  password    String
  permissions String[]    @default(["kanban"])
  boards      Board[]
  shortLinks  ShortLink[]
  notes       Note[]
  snippets    Snippet[]
}

model ShortLink {
  id        String   @id @default(uuid())
  code      String   @unique
  targetUrl String
  title     String?
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
}

model Note {
  id        String   @id @default(uuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
}

model Snippet {
  id        String   @id @default(uuid())
  title     String
  language  String   @default("plaintext")
  tags      String[] @default([])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
}

model Board {
  id      String   @id @default(uuid())
  title   String
  owner   User     @relation(fields: [ownerId], references: [id])
  ownerId String
  lists   List[]
  labels  Label[]
}

model List {
  id      String  @id @default(uuid())
  title   String
  board   Board   @relation(fields: [boardId], references: [id])
  boardId String
  order   Int
  cards   Card[]
}

model Card {
  id             String          @id @default(uuid())
  title          String
  description    String?
  dueDate        DateTime?
  list           List            @relation(fields: [listId], references: [id])
  listId         String
  order          Int
  labels         Label[]
  checklistItems ChecklistItem[]
}

model Label {
  id      String  @id @default(uuid())
  name    String
  color   String
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  boardId String
  cards   Card[]
}

model ChecklistItem {
  id     String  @id @default(uuid())
  text   String
  done   Boolean @default(false)
  order  Int
  card   Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  cardId String
}
